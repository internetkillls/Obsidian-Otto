{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Otto OA Research Memory",
  "type": "object",
  "required": ["schema", "updated_at", "store", "display", "evaluate"],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["otto.oa.research.memory.v1"]
    },
    "updated_at": {
      "type": "string"
    },
    "store": {
      "type": "object",
      "required": ["domain", "resource_log", "source_mix", "progress_snapshot"],
      "properties": {
        "domain": {
          "type": "string"
        },
        "source_mix": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resource_log": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["captured_at", "title", "source", "why_it_matters", "next_use"],
            "properties": {
              "captured_at": { "type": "string" },
              "title": { "type": "string" },
              "source": { "type": "string" },
              "url": { "type": "string" },
              "domain": { "type": "string" },
              "why_it_matters": { "type": "string" },
              "next_use": { "type": "string" },
              "open_access": { "type": "boolean" },
              "tag": { "type": "string" }
            }
          }
        },
        "progress_snapshot": {
          "type": "object",
          "required": ["latest_updated_at", "shadow_updated_at"],
          "properties": {
            "latest_updated_at": { "type": "string" },
            "shadow_updated_at": { "type": "string" },
            "recent_focus": { "type": "string" }
          }
        }
      }
    },
    "display": {
      "type": "object",
      "required": ["digest", "show_sources", "show_question"],
      "properties": {
        "digest": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "source", "why_it_matters", "next_use"],
            "properties": {
              "title": { "type": "string" },
              "source": { "type": "string" },
              "why_it_matters": { "type": "string" },
              "next_use": { "type": "string" }
            }
          }
        },
        "show_sources": {
          "type": "boolean"
        },
        "show_question": {
          "type": "boolean"
        }
      }
    },
    "evaluate": {
      "type": "object",
      "required": ["novelty_score", "relevance_score", "reuse_potential", "confidence", "freshness_score", "should_ask_user"],
      "properties": {
        "novelty_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reuse_potential": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "should_ask_user": {
          "type": "boolean"
        },
        "should_refresh_memory": {
          "type": "boolean"
        },
        "note_quality": {
          "type": "string"
        }
      }
    }
  }
}
