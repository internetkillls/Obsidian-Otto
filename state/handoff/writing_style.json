{
  "meta": {
    "name": "academic_paraphrase_and_notes_style",
    "version": "1.0.0",
    "scope": [
      "otto_daily_essay_lab",
      "otto_daily_essay_compile"
    ],
    "priority": "canonical_writing_contract"
  },
  "rewrite_style": {
    "identity": {
      "core_orientation": "analitis-kritis",
      "risk_preference": "precision_over_accessibility",
      "default_reader_assumption": "theoretically_literate"
    },
    "macro_structure": {
      "base_pattern": [
        "Phenomenal entry",
        "Ontological-epistemic entanglement",
        "Critical displacement",
        "Conditional-practical opening"
      ],
      "structural_variants": {
        "high_polemical_context": [
          "Immediate tension",
          "Epistemic reversal",
          "Normative exposure"
        ],
        "exploratory_context": [
          "Conceptual scaffolding",
          "Deferred tension",
          "Open-ended synthesis"
        ]
      }
    },
    "context_triggers": {
      "audience": {
        "specialist": {
          "assumptions": [
            "shared_theory",
            "implicit_methods"
          ],
          "moves": [
            "compress_exposition",
            "merge_ontology_epistemology",
            "allow_unresolved_claims"
          ]
        },
        "non_specialist": {
          "assumptions": [
            "partial_theory"
          ],
          "moves": [
            "explicit_signposting",
            "delay_abstraction",
            "add_micro-summaries"
          ]
        }
      },
      "text_function": {
        "exploratory": {
          "dominant_mode": "modal",
          "moves": [
            "raise_conditions",
            "suspend_conclusion",
            "foreground_uncertainty"
          ]
        },
        "assertive": {
          "dominant_mode": "declarative",
          "moves": [
            "early_commitment",
            "contrastive_framing",
            "limited_modal_language"
          ]
        },
        "corrective": {
          "dominant_mode": "diagnostic",
          "moves": [
            "expose_false_binary",
            "redefine_terms",
            "compress_counterarguments"
          ]
        }
      }
    },
    "syntax_rules": {
      "default": {
        "prefer_complex_clauses": true,
        "stacked_qualifiers": true,
        "controlled_ambiguity": true
      },
      "regulation": {
        "if_overcompression_detected": {
          "actions": [
            "insert_anchor_sentence",
            "add_example_or_case"
          ]
        },
        "if_reader_disorientation_desired": {
          "actions": [
            "remove_transitional_markers",
            "delay_definition"
          ]
        }
      }
    },
    "lexicon_features": {
      "conceptual_patterns": {
        "dual_terms": [
          "X-keter-X-an"
        ],
        "negative_formulations": [
          "bukan X melainkan Y",
          "tidak sekadar X"
        ]
      },
      "epistemic_modality": {
        "high": [
          "sejauh mana",
          "dalam kondisi apa",
          "apa implikasinya jika"
        ],
        "low": [
          "dengan demikian",
          "oleh karena itu"
        ]
      },
      "dialectical_markers": {
        "default": [
          "namun",
          "meskipun"
        ],
        "suppressed_when": [
          "polemical_flow"
        ]
      }
    },
    "argument_moves": {
      "preferred": [
        "conceptual_inversion",
        "assumption_exposure",
        "frame_displacement"
      ],
      "deliberate_omissions": [
        "full_resolution",
        "didactic_closure"
      ]
    },
    "compression_points": {
      "intentional": [
        "post-critical commentary",
        "metakritik implisit"
      ],
      "risk_zones": [
        "theory-dense transitions",
        "practice jump"
      ]
    },
    "failure_modes": {
      "typical": [
        "reader_anchor_loss",
        "implicit_practice_leap"
      ],
      "mitigation_rules": {
        "if_confusion_unproductive": [
          "add_micro-summary",
          "restate_core_claim_plainly"
        ],
        "if_confusion_productive": [
          "maintain_density",
          "resist_simplification"
        ]
      }
    },
    "emphasis_points": {
      "when_present": [
        "structural dominance",
        "epistemic constraints",
        "practice-as-conditional"
      ],
      "when_suppressed": [
        "moralizing tone",
        "final prescriptions"
      ]
    }
  }
}
