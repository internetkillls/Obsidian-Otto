{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Otto Shadow Research Memory",
  "type": "object",
  "required": ["schema", "updated_at", "store", "display", "evaluate"],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["otto.shadow.research.memory.v1"]
    },
    "updated_at": {
      "type": "string"
    },
    "store": {
      "type": "object",
      "required": ["last_cue", "domain", "insight_log", "resource_log", "question_queue", "progress_snapshot"],
      "properties": {
        "last_cue": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "insight_log": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["captured_at", "kind", "title", "summary", "source"],
            "properties": {
              "captured_at": { "type": "string" },
              "kind": {
                "type": "string",
                "enum": ["weakness_point", "genuine_insight", "academic_direction"]
              },
              "title": { "type": "string" },
              "summary": { "type": "string" },
              "source": { "type": "string" },
              "url": { "type": "string" },
              "evidence": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "resource_log": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["captured_at", "title", "source", "why_it_matters", "next_use"],
            "properties": {
              "captured_at": { "type": "string" },
              "title": { "type": "string" },
              "source": { "type": "string" },
              "url": { "type": "string" },
              "domain": { "type": "string" },
              "why_it_matters": { "type": "string" },
              "next_use": { "type": "string" },
              "open_access": { "type": "boolean" }
            }
          }
        },
        "question_queue": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["captured_at", "question", "reason"],
            "properties": {
              "captured_at": { "type": "string" },
              "question": { "type": "string" },
              "reason": { "type": "string" },
              "confidence": { "type": "number" }
            }
          }
        },
        "progress_snapshot": {
          "type": "object",
          "required": ["latest_updated_at", "profile_updated_at", "proactive_mode"],
          "properties": {
            "latest_updated_at": { "type": "string" },
            "profile_updated_at": { "type": "string" },
            "proactive_mode": { "type": "string" },
            "recent_focus": {
              "type": "string"
            }
          }
        }
      }
    },
    "display": {
      "type": "object",
      "required": ["shadow_note", "show_user_question", "show_sources"],
      "properties": {
        "shadow_note": {
          "type": "object",
          "required": ["WEAKNESS_POINT", "GENUINE_INSIGHT", "ACADEMIC_DIRECTION", "WHY_NOW", "USER_QUESTION", "NEXT_NOTE"],
          "properties": {
            "WEAKNESS_POINT": { "type": "string" },
            "GENUINE_INSIGHT": { "type": "string" },
            "ACADEMIC_DIRECTION": { "type": "string" },
            "WHY_NOW": { "type": "string" },
            "USER_QUESTION": { "type": "string" },
            "NEXT_NOTE": { "type": "string" }
          }
        },
        "show_user_question": {
          "type": "boolean"
        },
        "show_sources": {
          "type": "boolean"
        }
      }
    },
    "evaluate": {
      "type": "object",
      "required": ["novelty_score", "relevance_score", "actionability_score", "confidence", "freshness_score", "should_ask_user"],
      "properties": {
        "novelty_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "actionability_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "should_ask_user": {
          "type": "boolean"
        },
        "should_refresh_memory": {
          "type": "boolean"
        },
        "note_quality": {
          "type": "string"
        }
      }
    }
  }
}
